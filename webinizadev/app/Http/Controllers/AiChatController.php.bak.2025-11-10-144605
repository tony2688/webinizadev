<?php

namespace App\Http\Controllers;

use Illuminate\Http\Request;
use Illuminate\Support\Facades\Http;
use Illuminate\Support\Facades\Log;

class AiChatController extends Controller
{
    public function chat(Request $request)
    {
        // 1) Input
        $promptRaw = (string) $request->input('prompt', '');
        $prompt = trim($promptRaw);
        if ($prompt === '') {
            return response()->json(['error' => 'prompt vacío'], 422);
        }

        // 2) Config env
        $base        = rtrim(env('AI_BASE_URL', ''), '/');
        $path        = '/' . ltrim(env('AI_PATH', '/v1/generate'), '/');
        $model       = env('AI_MODEL', 'qwen2.5:7b-instruct-q4_K_M');
        $system      = env('AI_SYSTEM', 'Sos el asistente oficial de WebinizaDev.');
        $apiKey      = env('AI_API_KEY', '');
        $tenant      = env('AI_TENANT_ID', 'default');

        $temperature = (float) env('AI_TEMP', 0.3);
        $maxTokens   = (int) env('AI_MAX_TOKENS', 400);
        $timeout     = (int) env('AI_TIMEOUT', 45);
        $sslVerify   = filter_var(env('AI_SSL_VERIFY', true), FILTER_VALIDATE_BOOL);

        // RAG
        $kbName      = env('AI_KB', 'kb-webinizadev-v1');
        $topK        = (int) env('AI_TOP_K', 5);
        $minScore    = (float) env('AI_MIN_SCORE', 0.12);
        $fallback    = env('AI_FALLBACK', 'refuse'); // 'refuse' | 'llm'
        $refusalMsg  = env('AI_REFUSAL_MESSAGE', 'Solo puedo responder sobre WebinizaDev. ¿Querés consultar servicios, plazos o contacto?');

        // Guard de dominio
        $strict      = filter_var(env('AI_STRICT_DOMAIN', true), FILTER_VALIDATE_BOOL);
        $allowTerms  = $this->parseAllowTerms(env('AI_ALLOWED_TERMS', ''));

        if ($base === '')   return response()->json(['error' => 'AI_BASE_URL no configurado'], 500);
        if ($apiKey === '' || $tenant === '')
            return response()->json(['error' => 'Faltan credenciales AI_API_KEY / AI_TENANT_ID'], 500);

        // 3) Prefiltro de dominio (bloquea fuera de tema)
        if ($strict && !$this->isOnDomain($prompt, $allowTerms)) {
            return response()->json(['reply' => $this->humanize($refusalMsg, $request)]);
        }

        // 4) Router de FAQs (humanizado y “siempre responde”)
        if ($answer = $this->routeFAQ($prompt, $request)) {
            return response()->json(['reply' => $answer]);
        }

        // 5) Desambiguación leve
        $prompt = $this->normalizePrompt($prompt);

        // 6) Headers
        $headers = [
            'Content-Type' => 'application/json',
            'X-API-Key'    => $apiKey,
            'X-Tenant'     => $tenant,
        ];
        if (env('CF_ACCESS_CLIENT_ID') && env('CF_ACCESS_CLIENT_SECRET')) {
            $headers['CF-Access-Client-Id']     = env('CF_ACCESS_CLIENT_ID');
            $headers['CF-Access-Client-Secret'] = env('CF_ACCESS_CLIENT_SECRET');
        }

        // 7) Mensajes: tono humano + few-shots; reset contexto
        $style = "Tono cercano; argentino; frases cortas; sin jerga técnica salvo que la pidan; 1 emoji máximo si suma; CTA suave al cierre.";
        $messages = [
            ['role' => 'system', 'content' =>
                $system . ' ' . $style .
                ' Respondé SOLO sobre WebinizaDev (servicios, planes, proceso, contacto, equipo, proyectos). ' .
                ' Si te preguntan si sos una IA: decí que sí y que fuiste desarrollada por WebinizaDev. ' .
                ' No mencionar Alibaba Cloud / Aliyun u otras marcas. Si la consulta es ajena al dominio, devolvé exactamente el refusal_message.'
            ],

            // Few-shot identidad
            ['role' => 'user', 'content' => '¿Sos una IA?'],
            ['role' => 'assistant', 'content' => 'Sí 😊 Soy la asistente de WebinizaDev, hecha por nuestro equipo. Te ayudo con servicios, planes, proceso, contacto y equipo.'],

            // Few-shot landing
            ['role' => 'user', 'content' => '¿Qué es una landing page?'],
            ['role' => 'assistant', 'content' => 'Es una página enfocada en una sola acción (WhatsApp, presupuesto o registro). La entregamos responsive, con formulario, SEO básico y Analytics. Suele estar lista en 3–5 días.'],

            // Few-shot planes
            ['role' => 'user', 'content' => '¿Qué planes tienen?'],
            ['role' => 'assistant', 'content' =>
                "Trabajamos por módulos:\n".
                "• Landing Page — CTA claro + formulario + SEO básico.\n".
                "• Portfolio — galería de proyectos + secciones.\n".
                "• Institucional — varias secciones, blog y panel.\n".
                "• Sitio SEO — performance 90+ y datos estructurados.\n".
                "• E-commerce — catálogo, carrito, pagos e inventario.\n".
                "• Dashboard — usuarios, reportes y API.\n".
                "• Pack IA & Automatización — chatbot, RAG y flujos n8n."
            ],
        ];
        $messages[] = ['role' => 'user', 'content' => $prompt];

        $conversationId = 'wz-' . bin2hex(random_bytes(8)); // sesion única

        // 8) Payload
        $payload = [
            'tenant_id'       => $tenant,
            'model'           => $model,

            'messages'        => $messages, // muchos gateways priorizan esto
            'prompt'          => $prompt,   // otros usan prompt/system
            'system'          => $system,

            'stream'          => false,
            'temperature'     => $temperature,
            'max_tokens'      => $maxTokens,

            // RAG estricto
            'search'          => true,
            'kb'              => $kbName,
            'top_k'           => $topK,
            'min_score'       => $minScore,
            'fallback'        => $fallback,
            'refusal_message' => $refusalMsg,

            'reset_context'   => true,
            'conversation_id' => $conversationId,
        ];

        try {
            $http = Http::withHeaders($headers)->timeout($timeout);
            if (!$sslVerify) $http = $http->withoutVerifying();

            $resp = $http->post($base . $path, $payload);

            if (!$resp->successful()) {
                return response()->json([
                    'error'  => 'AI upstream',
                    'status' => $resp->status(),
                    'detail' => $resp->json() ?? $resp->body(),
                ], 502);
            }

            $json  = $resp->json() ?? [];
            $reply =
                $json['reply'] ??
                $json['response'] ??
                ($json['choices'][0]['message']['content'] ?? null) ??
                ($json['message']['content'] ?? null) ?? null;

            // Post-filtro: identidad/dominio + humanización final
            $reply = $this->sanitizeIdentity($reply, $refusalMsg);
            if (!is_string($reply) || trim($reply) === '') {
                $reply = $refusalMsg;
            }
            if ($strict && !$this->isOnDomain($promptRaw, $allowTerms)) {
                $reply = $refusalMsg;
            }

            // Cierre humano contextual
            $reply = $this->humanize($reply, $request);

            return response()->json([
                'reply' => $reply,
                'usage' => $json['usage'] ?? null,
                'model' => $json['model'] ?? $model,
            ]);
        } catch (\Throwable $e) {
            Log::warning('Fallo llamada a LLM', ['msg' => $e->getMessage()]);
            return response()->json([
                'error' => 'Excepción llamando al LLM',
                'msg'   => $e->getMessage(),
            ], 502);
        }
    }

    /* =======================
       Helpers (dominio/tono)
       ======================= */

    private function parseAllowTerms(?string $csv): array
    {
        $base = [
            'webinizadev','webiniza','web inicia dev','webiniza dev',
            'servicio','servicios','plan','planes','paquete','paquetes',
            'landing','landingpage','portfolio','institucional','seo','marketing','seo marketing',
            'ecommerce','e-commerce','tienda',
            'dashboard','crm','ia','inteligencia artificial','chatbot','n8n','automatizacion','automatización',
            'sitio','página','web','desarrollo web','diseño web','hosting','mantenimiento',
            'cotización','presupuesto','precios','proceso','plazo','soporte',
            'contacto','whatsapp','tucumán','tucuman',
            'gabriela bollati','antonio romero','matias giacobbe',
            'uv energía solar','uv energia solar','sdt audio visual'
        ];
        $extra = array_filter(array_map('trim', explode(',', (string) $csv)));
        return array_values(array_unique(array_map('mb_strtolower', array_merge($base, $extra))));
    }

    private function isOnDomain(string $text, array $allowList): bool
    {
        $q = mb_strtolower($text);
        foreach ($allowList as $kw) {
            if ($kw !== '' && mb_strpos($q, $kw) !== false) return true;
        }
        return false;
    }

    private function normalizePrompt(string $prompt): string
    {
        $q = mb_strtolower($prompt);
        $hasPlanes = (mb_strpos($q, 'planes') !== false) || (mb_strpos($q, 'plan') !== false);
        $off = (mb_strpos($q, 'viaje') !== false) || (mb_strpos($q, 'vuelo') !== false) ||
               (mb_strpos($q, 'hotel') !== false)  || (mb_strpos($q, 'turismo') !== false);

        if ($hasPlanes && !$off) {
            return 'Consulta sobre PLANES de servicios web de WebinizaDev (Landing / Portfolio / Página Institucional / Sitio SEO / E-commerce / Dashboard / Pack IA & Automatización). ' . $prompt;
        }
        return $prompt;
    }

    private function routeFAQ(string $prompt, Request $request): ?string
    {
        $p = mb_strtolower($prompt);

        // --- identidad
        if (preg_match('/\\b(so[s]?|eres|sos)\\s+una\\s+ia\\b/u', $p)) {
            $this->rememberTopic($request, 'identidad');
            return "Sí 😊 Soy la asistente de WebinizaDev, desarrollada por nuestro equipo. Te ayudo con servicios, planes, proceso, contacto y equipo. ¿Sobre qué querés empezar?";
        }

        // --- contacto
        if ($this->hasAny($p, ['contacto','whatsapp','teléfono','telefono','mail','correo','comunicar','hablar'])) {
            $this->rememberTopic($request, 'contacto');
            return "Podés escribirnos por WhatsApp al **+54 381 555-5648** o por mail a **info@webinizadev.com** (L-V 9 a 18 h). Si querés, te paso un mensaje tipo para contarnos tu proyecto.";
        }

        // --- servicios
        if ($this->hasAny($p, ['servicio','servicios','que hacen','qué hacen','ofrecen'])) {
            $this->rememberTopic($request, 'servicios');
            return "Ofrecemos: **Desarrollo Web**, **Diseño UI/UX**, **SEO & performance** y **IA & automatización**. ¿Querés que te detalle alguno?";
        }

        // --- n8n / automatización
        if ($this->hasAny($p, ['n8n','automatizacion','automatización','workflow','flujos','zapier'])) {
            $this->rememberTopic($request, 'n8n');
            return "Con **n8n** armamos automatizaciones: capturar leads → calificar → enviar a CRM/Sheets → WhatsApp/Email; recordatorios; recuperación de carrito; publicación en redes; integraciones (Sheets, Gmail, Notion, Webhooks, Mercado Pago, WhatsApp Business via proveedor). ¿Qué proceso querés automatizar?";
        }

        // --- SEO / marketing
        if ($this->hasAny($p, ['seo','seo marketing','marketing','posicionamiento','google ads','meta ads'])) {
            $this->rememberTopic($request, 'seo');
            return "En **SEO & performance** mejoramos velocidad, Core Web Vitals, datos estructurados y on-page para subir en Google. Si querés pauta, te orientamos con **Google/Meta Ads** según objetivo. ¿Tu sitio ya está online o estás por lanzar?";
        }

        // --- planes
        if ($this->hasAny($p, ['plan','planes','paquete','paquetes','precios','costos'])) {
            $this->rememberTopic($request, 'planes');
            return "Tenemos: **Landing**, **Portfolio**, **Institucional**, **Sitio SEO**, **E-commerce**, **Dashboard** y **Pack IA & Automatización**. Según tu objetivo te recomiendo el ideal. ¿Venta directa, generación de leads o presencia institucional?";
        }

        // --- landing page
        if ($this->hasAny($p, ['landing','landingpage','qué es una landing','que es una landing','ladingpage','lending'])) {
            $this->rememberTopic($request, 'landing');
            return "Una *landing page* busca una sola acción (WhatsApp, presupuesto o registro). Entregamos responsive, formulario, SEO básico y Analytics. Suele estar lista en **3–5 días**. ¿Tenés un ejemplo de referencia?";
        }

        // --- quiénes son
        if ($this->hasAny($p, ['quienes son','quiénes son','sobre webinizadev','quien es webinizadev','cuentame sobre webiniza','cuéntame sobre webiniza'])) {
            $this->rememberTopic($request, 'sobre');
            return "Somos **WebinizaDev**, estudio de Tucumán. Combinamos tecnología, diseño e IA para sitios rápidos y medibles. Trabajamos con PyMEs y profesionales en Argentina. ¿Buscás web nueva, tienda o mejorar la que ya tenés?";
        }

        // --- soporte / mantenimiento
        if ($this->hasAny($p, ['soporte','mantenimiento','actualizaciones','backup'])) {
            $this->rememberTopic($request, 'soporte');
            return "Sí, tenemos mantenimiento mensual: actualizaciones, backups y mejoras de performance/SEO. Si me pasás la URL o el stack, te sugiero un plan.";
        }

        return null; // que responda el RAG
    }

    private function hasAny(string $haystack, array $needles): bool
    {
        foreach ($needles as $n) if (mb_strpos($haystack, $n) !== false) return true;
        return false;
    }

    // Guardar último tema para cierres más humanos
    private function rememberTopic(Request $r, string $topic): void
    {
        $r->session()->put('ai_last_topic', $topic);
    }

    // Cierre humano y amable, con mini-memoria
    private function humanize(string $text, Request $r): string
    {
        $topic = (string) $r->session()->get('ai_last_topic', '');
        $closers = [
            'contacto'  => '¿Querés que te deje un mensaje listo para WhatsApp?',
            'planes'    => 'Si me contás tu objetivo, te recomiendo un plan en 1 línea.',
            'servicios' => '¿Querés que te muestre ejemplos o tiempos de entrega?',
            'landing'   => '¿La querés para leads por WhatsApp o para presupuestos?',
            'seo'       => '¿Tenés la URL para mirar performance y darte tips?',
            'n8n'       => 'Decime tu proceso y te digo cómo lo automatizamos.',
            'sobre'     => '¿Te paso links a proyectos que te puedan servir de referencia?',
            'soporte'   => '¿Preferís mantenimiento mensual o por horas?',
            'identidad' => '¿Seguimos por servicios, planes o contacto?',
            ''          => '¿Te doy una mano con servicios, planes o contacto?',
        ];
        $tail = $closers[$topic] ?? $closers[''];
        // Evitar duplicar cierre si ya trae interrogante similar
        if (mb_stripos($text, '¿') === false && mb_stripos($text, '?') === false) {
            return rtrim($text) . ' ' . $tail;
        }
        return $text;
    }

    // Identidad segura (nunca Alibaba/Aliyun/etc.)
    private function sanitizeIdentity($text, string $refusalMsg): string
    {
        if (!is_string($text) || $text === '') return $refusalMsg;

        $foreign = [
            '/\\bAlibaba\\s*Cloud\\b/i','/\\bAliyun\\b/i','/\\bOpenAI\\b/i',
            '/\\bAnthropic\\b/i','/\\bGoogle\\b/i','/\\bMicrosoft\\b/i'
        ];
        foreach ($foreign as $p) {
            if (preg_match($p, $text)) {
                return "Sí 😊 Soy la asistente de WebinizaDev, desarrollada por nuestro equipo. Te ayudo con servicios, planes, proceso, contacto y equipo.";
            }
        }

        if (stripos($text, 'solo puedo responder sobre webinizadev') !== false) {
            return $text . ' ¿Querés que te cuente nuestros planes o cómo trabajamos?';
        }
        return $text;
    }
}
